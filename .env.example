# ============================================================
# AgentPlatform — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ----- LLM providers (at least one required) -----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ----- MCP Server auth key -----
# Any random string. Must match what you enter in the Tools UI
# when registering the local MCP server (URL: http://mcp_server:8001).
MCP_API_KEY=change-me-to-something-secret

# ----- Telegram bot (optional) -----
TELEGRAM_BOT_TOKEN=

# ----- LangSmith tracing (optional) -----
# Remove or leave blank to disable tracing.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_PROJECT=agentplatform

# ----- Database & Redis -----
# These defaults match the Docker Compose service names.
# Only change if you're pointing at external services.
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/agentdb
SYNC_DATABASE_URL=postgresql://agent:agent@postgres:5432/agentdb
REDIS_URL=redis://redis:6379/0
