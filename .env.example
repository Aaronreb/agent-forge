# Copy to .env and fill in your values
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=

# LangSmith tracing (optional — remove or leave blank to disable)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=agentplatform

# DB / Redis are pre-configured for Docker Compose; only change for external services
DATABASE_URL=postgresql+asyncpg://agent:agent@postgres:5432/agentdb
SYNC_DATABASE_URL=postgresql://agent:agent@postgres:5432/agentdb
REDIS_URL=redis://redis:6379/0
